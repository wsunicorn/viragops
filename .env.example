# ============================================================
# LLMOps RAG Platform — biến môi trường mẫu
# Copy thành `.env` và điền giá trị thật. KHÔNG commit file .env.
# ============================================================

# --- App ---
APP_ENV=local                # local | ci | production-like
APP_PORT=8000
LOG_LEVEL=INFO

# --- PostgreSQL (metadata, prompt registry, feedback) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=llmops
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me

# --- Qdrant (vector index) ---
QDRANT_URL=http://localhost:6333

# --- Valkey/Redis (semantic cache, queue) ---
VALKEY_URL=redis://localhost:6379/0

# --- LiteLLM Model Gateway (Phase 7) ---
# LITELLM_MASTER_KEY: bất kỳ chuỗi nào, dùng làm Bearer token gọi proxy local.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=

# --- Provider API keys (chỉ dùng qua gateway, không gọi trực tiếp) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GEMINI_API_KEY_2/_3/_4: key phụ (project Google khác) — dùng khi key
# chính cạn quota free tier (đo thật ở Phase 4: 1000 request-item/ngày/
# project — đo thật lại 2026-07-12: eval quy mô 300 câu/full re-index cần
# tới 4 key mới đủ chạy trong 1 phiên). GEMINI_API_KEY_2 cấu hình làm
# fallback thứ 2 trong config/litellm_config.yaml; _3/_4 hiện chỉ dùng
# trong scripts/dataops embedding (src/dataops/embedder.py _clients()),
# chưa thêm vào litellm_config.yaml.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# --- Langfuse observability (Phase 10) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- MinIO object store (Phase 3+) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me
