# ============================================================
# LLMOps RAG Platform — biến môi trường mẫu
# Copy thành `.env` và điền giá trị thật. KHÔNG commit file .env.
# ============================================================

# --- App ---
APP_ENV=local                # local | ci | production-like
APP_PORT=8000
LOG_LEVEL=INFO

# --- PostgreSQL (metadata, prompt registry, feedback) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=llmops
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me

# --- Qdrant (vector index) ---
QDRANT_URL=http://localhost:6333

# --- Valkey/Redis (semantic cache, queue) ---
VALKEY_URL=redis://localhost:6379/0

# --- LiteLLM Model Gateway (Phase 7) ---
# LITELLM_MASTER_KEY: bất kỳ chuỗi nào, dùng làm Bearer token gọi proxy local.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=

# --- Provider API keys (chỉ dùng qua gateway, không gọi trực tiếp) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GEMINI_API_KEY_2/_3/_4/_5: key phụ (project Google khác) — dùng khi key
# chính cạn quota free tier (đo thật ở Phase 4: 1000 request-item/ngày/
# project — đo thật lại 2026-07-12: eval quy mô 300 câu/full re-index cần
# tới 4 key mới đủ chạy trong 1 phiên). GEMINI_API_KEY_2 cấu hình làm
# fallback thứ 2 trong config/litellm_config.yaml; _3/_4 hiện chỉ dùng
# trong scripts/dataops embedding (src/dataops/embedder.py _clients()),
# chưa thêm vào litellm_config.yaml. GEMINI_API_KEY_5 = chặng fallback thứ
# 3 (`tertiary`) trong litellm_config.yaml + docker-compose.yml — thêm
# 2026-07-12 khi Phase 8 chạy nhiều eval liên tiếp trong 1 ngày làm cạn
# SẠCH cả primary lẫn secondary cùng lúc.
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# --- Langfuse observability (Phase 10) — Cloud (free tier), KHÔNG
# self-host (xem CHECKLIST Phase 10 cho quyết định). Tự tạo tài khoản tại
# cloud.langfuse.com, lấy 2 key ở Project Settings > API Keys.
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Grafana (Phase 10) ---
GRAFANA_ADMIN_PASSWORD=admin
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me
